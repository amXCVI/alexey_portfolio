---
import CaseLayout from '../../components/CaseLayout.astro';
import CaseHero from '../../components/CaseHero.astro';
import CaseSection from '../../components/CaseSection.astro';
import CaseResult from '../../components/CaseResult.astro';
import CaseBanner from '../../components/CaseBanner.astro';
// CaseImage and CaseGallery are ready for the image slots below — imported in
// this page once the Figma binaries are exported (see IMAGERY note).
import { arSpatially } from '../../data/cases/ar-spatially.ts';

// ---------------------------------------------------------------------------
// IMAGERY — BLOCKED this billing cycle.
// The Figma MCP server is on the Starter plan (6 read tool calls / MONTH).
// get_metadata(397-5037) succeeded and provided all the copy below, but the
// asset download URLs are only returned by get_design_context, which is now
// past quota. When the quota resets, export the following nodes into
// src/assets/cases/ar-spatially/ and import them here, then drop them into the
// marked slots (CaseImage / CaseGallery / CaseBanner) in section order:
//
//   444:32  image 11 .............. iteration-01.png   (первый вариант интерфейса)
//   444:31  Vector ................ iteration-02.png   (второй вариант интерфейса)
//   407:5281 phone row (6 screens). final-screens-*.png (И конечный вариант)
//   425:4777 image 7 .............. flow-ar-anchor.png (User Flow: AR-anchor)
//   416:4728 image 5 .............. flow-navigation.png (многоуровневая навигация)
//   408:9445 phone row (6 screens). ux-screens-*.png   (Основные UX-вызовы)
//   418:4753 image 6 .............. flow-positioning.png (позиционирование AR объекта)
// ---------------------------------------------------------------------------

const { title, meta, description, tags, sections, result } = arSpatially;
const [intro, goal, stages, challenges, decisions] = sections;
---

<CaseLayout title={title}>
  <CaseHero title={title} meta={meta} description={description} tags={tags} />

  {/* Intro — company context + team roster */}
  <CaseSection heading={intro.heading} list={intro.list}>
    {intro.paragraphs?.map((p) => <p>{p}</p>)}
    {intro.footnotes?.map((p) => <p>{p}</p>)}
  </CaseSection>

  {/* Цель проекта */}
  <CaseSection heading={goal.heading} list={goal.list}>
    {goal.paragraphs?.map((p) => <p>{p}</p>)}
    {goal.footnotes?.map((p) => <p>{p}</p>)}
  </CaseSection>

  {/* Этапы создания проекта */}
  <CaseSection heading={stages.heading}>
    {stages.paragraphs?.map((p) => <p>{p}</p>)}
    {stages.footnotes?.map((p) => <p>{p}</p>)}
  </CaseSection>

  {/*
    IMAGE SLOT (444:21): two iteration mockups + the final 6-screen row.
    Caption plates rendered as CaseBanner so the design intent is preserved
    even before the binaries are exported.
  */}
  <div class="iteration-row">
    <CaseBanner title="первый вариант интерфейса" />
    <CaseBanner title="второй вариант интерфейса" />
  </div>
  <p class="row-label">И конечный вариант</p>

  {/* Основные UX-вызовы */}
  <CaseSection heading={challenges.heading}>
    {challenges.paragraphs?.map((p) => <p>{p}</p>)}
  </CaseSection>

  {/* Ключевые решения — heading→body blocks */}
  <CaseSection heading={decisions.heading}>
    <dl class="decisions">
      {
        decisions.blocks?.map((b) => (
          <div class="decision">
            <dt>{b.title}</dt>
            <dd>{b.body}</dd>
          </div>
        ))
      }
    </dl>
  </CaseSection>

  {/* Результат */}
  <CaseResult heading={result.heading} items={result.items}>
    {result.intro?.map((p) => <p>{p}</p>)}
    {
      result.achievements && (
        <div slot="achievements" class="achievements">
          <p class="achievements__title">{result.achievements.heading}</p>
          <ul class="bullets">
            {result.achievements.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      )
    }
  </CaseResult>
</CaseLayout>

<style>
  .iteration-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .row-label {
    font-size: var(--fs-role);
    font-weight: var(--fw-medium);
    color: var(--color-heading);
    text-align: center;
  }

  .decisions {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .decision {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .decision dt {
    font-size: var(--fs-role);
    font-weight: var(--fw-medium);
    color: var(--color-heading);
    line-height: var(--lh-32);
  }

  .decision dd {
    margin: 0;
    color: var(--color-text);
    line-height: var(--lh-30);
  }

  .achievements {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .achievements__title {
    font-size: var(--fs-role);
    font-weight: var(--fw-medium);
    color: var(--color-heading);
  }

  @media (max-width: 640px) {
    .iteration-row {
      grid-template-columns: 1fr;
    }
    .row-label {
      text-align: left;
    }
  }
</style>
