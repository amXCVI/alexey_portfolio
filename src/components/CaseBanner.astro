---
/**
 * CaseBanner — a dark feature banner (e.g. caption plate or call-out strip).
 * Uses the dark banner tokens so text meets contrast on the dark surface.
 * Optional `title`; arbitrary body via the default slot.
 */
export interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<aside class="case-banner">
  {title && <p class="case-banner__title">{title}</p>}
  <slot />
</aside>

<style>
  .case-banner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    background: var(--color-banner-bg);
    color: var(--color-on-dark);
    border-radius: var(--radius-pill);
    text-align: center;
  }

  .case-banner__title {
    font-size: var(--fs-sub);
    font-weight: var(--fw-medium);
    line-height: var(--lh-30);
    color: var(--color-on-dark);
  }

  .case-banner :global(p) {
    color: var(--color-on-dark);
    line-height: var(--lh-30);
  }
</style>
