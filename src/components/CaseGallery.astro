---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/**
 * CaseGallery — a responsive grid of images (e.g. phone-mockup rows). On wide
 * viewports it auto-fits as many columns as fit; on narrow viewports it
 * collapses to a single column. Never overflows the body horizontally.
 */
export interface Props {
  images: { src: ImageMetadata; alt: string; caption?: string }[];
  /** Minimum column width before reflow (default 140px — phone mockups). */
  minColumn?: string;
}

const { images, minColumn = '140px' } = Astro.props;
---

<ul class="case-gallery" style={`--min-col: ${minColumn}`}>
  {
    images.map((img) => (
      <li class="case-gallery__item">
        <Image src={img.src} alt={img.alt} class="case-gallery__img" />
        {img.caption && <span class="case-gallery__caption">{img.caption}</span>}
      </li>
    ))
  }
</ul>

<style>
  .case-gallery {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(var(--min-col), 1fr));
    gap: var(--space-4);
    align-items: end;
  }

  .case-gallery__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
  }

  .case-gallery__img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-media);
  }

  .case-gallery__caption {
    font-size: var(--fs-sub);
    color: var(--color-muted);
    line-height: var(--lh-30);
    text-align: center;
  }

  @media (max-width: 640px) {
    .case-gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
